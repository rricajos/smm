{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "types": [],
    "paths": {
      "$lib/*": ["./src/lib/*"],
      "$types/*": ["./src/types/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.svelte"]
}
